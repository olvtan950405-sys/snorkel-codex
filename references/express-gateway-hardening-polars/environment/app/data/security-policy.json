{
  "policy_version": "GATEWAY-SEC-2026-06",
  "allowed_cipher_suites": [
    "TLS_AES_128_GCM_SHA256",
    "TLS_AES_256_GCM_SHA384",
    "TLS_CHACHA20_POLY1305_SHA256"
  ],
  "minimum_key_bits": {
    "EC": 256,
    "Ed25519": 256,
    "RSA": 2048
  },
  "require_mutual_tls": true,
  "public_route_paths": [
    "/healthz",
    "/status"
  ]
}
