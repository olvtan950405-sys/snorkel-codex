#!/usr/bin/env python3
import sys
from pathlib import Path

# Direct script execution adds /app/bin, not /app, to sys.path. Resolve the
# application root from this launcher's own location so the CLI works from any
# verifier or operator working directory.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from walkeeper.cli import main
raise SystemExit(main())
