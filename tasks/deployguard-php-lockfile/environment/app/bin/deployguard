#!/bin/sh
set -eu
[ "${1:-}" = serve ] || { echo 'usage: deployguard serve --host HOST --port PORT --database DB' >&2; exit 2; }
shift
host=127.0.0.1 port=8080 database=/app/data/deployguard.sqlite
while [ "$#" -gt 0 ]; do
  case "$1" in
    --host) host=$2; shift 2;;
    --port) port=$2; shift 2;;
    --database) database=$2; shift 2;;
    *) echo "unknown argument: $1" >&2; exit 2;;
  esac
done
export DEPLOYGUARD_DATABASE="$database"
exec php -S "$host:$port" -t /app/public /app/public/index.php
