#!/usr/bin/env lua5.4
package.path = "/app/?.lua;" .. package.path
local service = require("verify_service")

local port
for i = 1, #arg do
  if arg[i] == "--port" then port = tonumber(arg[i + 1]) end
end
if not port then
  io.stderr:write("usage: lockguard --port <n>\n")
  os.exit(2)
end
service.serve(port)
